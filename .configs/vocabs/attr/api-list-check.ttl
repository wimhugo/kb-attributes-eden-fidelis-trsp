@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

trsp:checklistAPI
  a skos:ConceptScheme ;
  skos:prefLabel "Checklist for APIs"@en ;
  dct:title "Checklist for APIs"@en ;
  dct:description "List of API service types/ protocols available"@en ;
  dct:created "2026-04-29T00:00:00+00:00"^^xsd:datetime ;
  dct:creator <https://orcid.org/0000-0002-0255-5101> ;
  dct:contributor <https://orcid.org/0000-0003-1106-8441> ;
  dct:contributor <https://orcid.org/0000-0002-3200-2698> ;
  owl:versionInfo "0.1" .

trsp:oai-pmh
  a skos:Concept ;
  skos:prefLabel "OAI-PMH Harvesting Endpoint"@en ;
  skos:inScheme trsp:checklistAPI .

trsp:csw
  a skos:Concept ;
  skos:prefLabel "OGC CS/W Harvesting Endpoint"@en ;
  skos:inScheme trsp:checklistAPI .

trsp:rest
  a skos:Concept ;
  skos:prefLabel "REST API"@en ;
  skos:inScheme trsp:checklistAPI .

trsp:sparql
  a skos:Concept ;
  skos:prefLabel "SPARQL Endpoint"@en ;
  skos:inScheme trsp:checklistAPI .

trsp:graphql
  a skos:Concept ;
  skos:prefLabel "GraphQL Endpoint"@en ;
  skos:inScheme trsp:checklistAPI .
