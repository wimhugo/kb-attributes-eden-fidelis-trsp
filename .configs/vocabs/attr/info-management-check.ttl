@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

trsp:checklistInfoManagement
  a skos:ConceptScheme ;
  skos:prefLabel "Information Management"@en ;
  dct:title "Information Management"@en ;
  dct:created "2026-05-07"^^xsd:date ;
  dct:modified "2026-05-07"^^xsd:date ;
  owl:versionInfo "0.1" .

trsp:iso20000
  a skos:Concept ;
  skos:prefLabel "ISO 20000"@en ;
  skos:description "Certifiable IT service management standard"@en ;
  skos:seeAlso <https://www.iso.org/standard/70636.html> ;
  skos:inScheme trsp:checklistInfoManagement .

trsp:iso27001
  a skos:Concept ;
  skos:prefLabel "ISO 27001"@en ;
  skos:description "Information Security Management Systems (ISMS)"@en ;
  skos:seeAlso <https://www.iso.org/standard/27001> ;
  skos:inScheme trsp:checklistInfoManagement .

trsp:cobit
  a skos:Concept ;
  skos:prefLabel "COBIT"@en ;
  skos:description "Governance, control, audit, risk management"@en ;
  skos:seeAlso <https://www.isaca.org/resources/cobit> ;
  skos:inScheme trsp:checklistInfoManagement .

trsp:itil
  a skos:Concept ;
  skos:prefLabel "ITIL"@en ;
  skos:description "IT Service Management (ITSM) best practices"@en ;
  skos:seeAlso <https://www.itil.com> ;
  skos:inScheme trsp:checklistInfoManagement .

trsp:fitsm
  a skos:Concept ;
  skos:prefLabel "FitSM"@en ;
  skos:description "Lightweight ITSM, especially research infrastructures"@en ;
  skos:seeAlso <https://www.fitsm.eu> ;
  skos:inScheme trsp:checklistInfoManagement .
