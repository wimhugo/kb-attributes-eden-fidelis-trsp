@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

trsp:versioning-strategy-type-scheme
  a skos:ConceptScheme ;
  skos:prefLabel "Versioning Strategy Vocabulary"@en ;
  dct:title "Versioning Strategy Vocabulary"@en ;
  dct:created "2026-05-03"^^xsd:date ;
  dct:modified "2026-05-04"^^xsd:date ;
  owl:versionInfo "0.2" .

trsp:stableCitationReference
  a skos:Concept ;
  skos:prefLabel "Stable Citation/ Reference"@en ;
  skos:inScheme trsp:versioning-strategy-type-scheme .

trsp:reproducibilityAndAuthenticity
  a skos:Concept ;
  skos:prefLabel "Reproducibility and Authenticity"@en ;
  skos:inScheme trsp:versioning-strategy-type-scheme .

trsp:contentEvolution
  a skos:Concept ;
  skos:prefLabel "Content Evolution"@en ;
  skos:closeMatch <https://doi.org/10.25504/FAIRsharing.ochiOn> ;
  rdfs:seeAlso <https://doi.org/10.25504/FAIRsharing.ochiOn> ;
  skos:inScheme trsp:versioning-strategy-type-scheme .

trsp:dynamicContentGrowth
  a skos:Concept ;
  skos:prefLabel "Dynamic Content Growth"@en ;
  skos:inScheme trsp:versioning-strategy-type-scheme .
