@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

trsp:rights-encoding-type-scheme
  a skos:ConceptScheme ;
  skos:prefLabel "Rights Encoding Vocabulary"@en ;
  dct:title "Rights Encoding Vocabulary"@en ;
  dct:created "2026-05-03"^^xsd:date ;
  dct:modified "2026-05-04"^^xsd:date ;
  owl:versionInfo "0.2" .

trsp:rel
  a skos:Concept ;
  skos:prefLabel "REL"@en ;
  skos:inScheme trsp:rights-encoding-type-scheme .

trsp:ccrel
  a skos:Concept ;
  skos:prefLabel "CCREL"@en ;
  skos:inScheme trsp:rights-encoding-type-scheme .

trsp:odrl
  a skos:Concept ;
  skos:prefLabel "ODRL"@en ;
  skos:broadMatch <http://www.w3.org/ns/odrl/2/core> ;
  rdfs:seeAlso <http://www.w3.org/ns/odrl/2/core> ;
  skos:inScheme trsp:rights-encoding-type-scheme .

trsp:rsl
  a skos:Concept ;
  skos:prefLabel "RSL"@en ;
  skos:inScheme trsp:rights-encoding-type-scheme .

trsp:openrel
  a skos:Concept ;
  skos:prefLabel "OpenREL"@en ;
  skos:inScheme trsp:rights-encoding-type-scheme .

trsp:rightsstatementsorg
  a skos:Concept ;
  skos:prefLabel "Rightsstatements.org"@en ;
  skos:inScheme trsp:rights-encoding-type-scheme .
