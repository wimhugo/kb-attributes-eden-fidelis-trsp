@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .
@prefix care: <https://purl.org/trsp/care/> .
@prefix fair: <https://w3id.org/fair/principles/terms/> .
@prefix gorc: <https://purl.org/gorc/> .
@prefix eden: <www.example.com/eden> .   ## to be updated

trsp:checklistPolicies
  a skos:ConceptScheme ;
  skos:prefLabel "Checklist of Policies"@en ;
  dct:title "Checklist of Policies"@en ;
  dct:created "2026-05-03"^^xsd:date ;
  dct:modified "2026-05-03"^^xsd:date ;
  owl:versionInfo "0.3" .

trsp:versioning
  a skos:Concept ;
  skos:prefLabel "Versioning"@en ;
  skos:broadMatch <http://purl.org/pav/> ;
  rdfs:seeAlso <http://purl.org/pav/> ;
  skos:inScheme trsp:checklistPolicies .

trsp:retention
  a skos:Concept ;
  skos:prefLabel "Retention"@en ;
  skos:broadMatch <http://linkeddata.center/kees/v1#RetentionPolicy> ;
  rdfs:seeAlso <http://linkeddata.center/kees/v1#RetentionPolicy> ;
  skos:inScheme trsp:checklistPolicies .

trsp:preservation
  a skos:Concept ;
  skos:prefLabel "Preservation"@en ;
  skos:inScheme trsp:checklistPolicies .

trsp:deposit
  a skos:Concept ;
  skos:prefLabel "Deposition Policy"@en ;
  skos:exactMatch eden:depositionPolicy ;    ## to be updated
  skos:inScheme trsp:checklistPolicies .

trsp:sustainability
  a skos:Concept ;
  skos:prefLabel "Sustainability Policy"@en ;
  skos:exactMatch eden:sustainabilityPolicy ;    ## to be updated
  skos:inScheme trsp:checklistPolicies .

trsp:appraisal
  a skos:Concept ;
  skos:prefLabel "Appraisal"@en ;
  skos:broadMatch <http://culturalis.org/oad#appraisalDestructionAndSchedulingInformation> ;
  rdfs:seeAlso <http://culturalis.org/oad#appraisalDestructionAndSchedulingInformation> ;
  skos:inScheme trsp:checklistPolicies .

trsp:accession
  a skos:Concept ;
  skos:prefLabel "Accession"@en ;
  skos:inScheme trsp:checklistPolicies .

trsp:disclosureRiskAssessment
  a skos:Concept ;
  skos:prefLabel "Disclosure Risk Assessment"@en ;
  skos:inScheme trsp:checklistPolicies .

trsp:access
  a skos:Concept ;
  skos:prefLabel "Access and Request Assessment"@en ;
  skos:inScheme trsp:checklistPolicies .

trsp:bibliographicMetadata
  a skos:Concept ;
  skos:prefLabel "Bibliographic Metadata"@en ;
  skos:exactMatch <http://purl.org/spar/fabio/BibliographicMetadata> ;
  rdfs:seeAlso <http://purl.org/spar/fabio/BibliographicMetadata> ;
  skos:inScheme trsp:checklistPolicies .

trsp:policyDevelopment
  a skos:Concept ;
  skos:prefLabel "Policy Development"@en ;
  skos:inScheme trsp:checklistPolicies .

trsp:ethicsClearanceVerification
  a skos:Concept ;
  skos:prefLabel "Ethics Clearance Verification"@en ;
  skos:inScheme trsp:checklistPolicies .

trsp:persistentIdentifier
  a skos:Concept ;
  skos:prefLabel "Persistent Identifier"@en ;
  skos:exactMatch gorc:pid ;
  rdfs:seeAlso gorc:pid ;
  skos:broadMatch fair:F1 ;
  rdfs:seeAlso fair:F1 ;
  skos:inScheme trsp:checklistPolicies .

trsp:licence
  a skos:Concept ;
  skos:prefLabel "Licence"@en ;
  skos:inScheme trsp:checklistPolicies .

trsp:preferredFormats
  a skos:Concept ;
  skos:prefLabel "Preferred Formats"@en ;
  skos:inScheme trsp:checklistPolicies .

trsp:compliance
  a skos:Concept ;
  skos:prefLabel "Compliance"@en ;
  skos:broadMatch <http://purl.obolibrary.org/obo/OBI_0500023> ;
  rdfs:seeAlso <http://purl.obolibrary.org/obo/OBI_0500023> ;
  skos:inScheme trsp:checklistPolicies .

trsp:rights
  a skos:Concept ;
  skos:prefLabel "Rights"@en ;
  skos:exactMatch <http://bblfish.net/work/atom-owl/2006-06-06/#rights> ;
  rdfs:seeAlso <http://bblfish.net/work/atom-owl/2006-06-06/#rights> ;
  skos:broadMatch care:A1 ;
  rdfs:seeAlso care:A1 ;
  skos:inScheme trsp:checklistPolicies .

trsp:responsibleAI
  a skos:Concept ;
  skos:prefLabel "Responsible Use of AI in the Organisation"@en ;
  skos:inScheme trsp:checklistPolicies .

trsp:interoprability
  a skos:Concept ;
  skos:prefLabel "Interoprability"@en ;
  skos:inScheme trsp:checklistPolicies .

trsp:dataSecurityAndIntegrity
  a skos:Concept ;
  skos:prefLabel "Data Security and Integrity"@en ;
  skos:inScheme trsp:checklistPolicies .
