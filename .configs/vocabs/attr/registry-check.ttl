@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

trsp:checklistRegistry
  a skos:ConceptScheme ;
  skos:prefLabel "Checklist for Registries"@en ;
  dct:title "Checklist for Registry Sources"@en ;
  dct:description "List of registry sources of identifiers for specific entities"@en ;
  dct:created "2026-07-02T00:00:00+00:00"^^xsd:datetime ;
  dct:creator <https://orcid.org/0000-0002-0255-5101> ;
  skos:note "This is just a subset of entries that can be obtained from https://cat.argo.grnet.gr/pid-selection."@en ;
  owl:versionInfo "0.1" .

trsp:institution-registry
  a skos:Concept ;
  skos:prefLabel "Institution and Organisation Registries"@en ;
  skos:inScheme trsp:checklistRegistry .

trsp:institution-registry-ror
  a skos:Concept ;
  skos:prefLabel "Research Organisation Registry"@en ;
  dct:type dcat:Institution ;
  dcat:endpointURL <https://api.ror.org/v2/organizations> ;
  skos:broader trsp:institution-registry;
  skos:inScheme trsp:checklistRegistry .

trsp:institution-registry-crf
  a skos:Concept ;
  skos:prefLabel "Crossref Funders"@en ;
  rdfs:definition "The Funder Registry is an open registry of persistent identifiers for grant-giving organizations around the world."@en ;
  dct:type dcat:Institution ;
  dcat:type schema:FundingAgency ;
  dcat:endpointURL <https://api.crossref.org/funders> ;
  skos:broader trsp:institution-registry;
  skos:inScheme trsp:checklistRegistry .



