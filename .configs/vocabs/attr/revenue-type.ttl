@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <https://vocab.example.org/> .

trsp:profile-test-type-scheme a skos:ConceptScheme ;
  dct:created "2026-04-29T00:00:00+00:00"^^xsd:datetime;
  dct:creator <https://orcid.org/0000-0002-0255-5101>;
  dct:contributor <https://orcid.org/0000-0003-1106-8441>;
  skos:definition "Revenue Type determines the technical mechanism for revenue generation and cost recovery."@en;
  dct:modified "2026-04-30"^^xsd:datetime;
  prov:wasAssociatedWith  
     [ a prov:SoftwareAgent;
         prov:label "TRSP B Curation Platform" .
     ] ;
  dct:rights <https://spdx.org/licenses/CC0-1.0>;
  dct:title "Revenue Type"@en;
  dct:source "https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/commit/cbd080c62fae05587d00590b22f1476556e75697" ;
  skos:prefLabel "TRSP Revenue Type Vocabulary"@en;
  owl:versionInfo "0.4"@en;
  foaf:homepage  <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

trsp:revenue-type-free
  a skos:Concept ;
  skos:prefLabel "Free"@en ;
  skos:definition "No payment or attribution required."@en ;
  dcterms:source <https://rslstandard.org/rsl#_3-7-payment-compensation-terms> ;
  skos:inScheme trsp:ConceptScheme .

trsp:revenue-type-payment
  a skos:Concept ;
  skos:prefLabel "Purchase"@en ;
  skos:definition "One-time payment."@en ;
  dcterms:source <https://rslstandard.org/rsl#_3-7-payment-compensation-terms> ;
  skos:closeMatch <http://purl.org/cerif/frapo/Purchaser> ;
  skos:broadMatch <http://purl.org/cerif/frapo/Purchaser> ;
  rdfs:seeAlso <http://purl.org/cerif/frapo/Purchaser> ;
  skos:inScheme trsp:ConceptScheme .

trsp:revenue-type-recurring
  a skos:Concept ;
  skos:prefLabel "Subscription"@en ;
  skos:definition "Recurring payment for access."@en ;
  dcterms:source <https://rslstandard.org/rsl#_3-7-payment-compensation-terms> ;
  skos:closeMatch <http://purl.org/cerif/frapo/Subscription> ;
  skos:exactMatch <http://purl.org/cerif/frapo/Subscription> ;
  rdfs:seeAlso <http://purl.org/cerif/frapo/Subscription> ;
  skos:inScheme trsp:ConceptScheme .

trsp:revenue-type-recurring
  a skos:Concept ;
  skos:prefLabel "Subscription"@en ;
  skos:definition "Recurring payment for access."@en ;
  dcterms:source <https://rslstandard.org/rsl#_3-7-payment-compensation-terms> ;
  skos:closeMatch <http://purl.org/cerif/frapo/Subscription> ;
  skos:exactMatch <http://purl.org/cerif/frapo/Subscription> ;
  rdfs:seeAlso <http://purl.org/cerif/frapo/Subscription> ;
  skos:inScheme trsp:ConceptScheme .

trsp:revenue-type-ai-training
  a skos:Concept ;
  skos:prefLabel "AI Training"@en ;
  skos:definition "Payment every time the content is used for AI training."@en ;
  dcterms:source <https://rslstandard.org/rsl#_3-7-payment-compensation-terms> ;
  skos:inScheme trsp:ConceptScheme .

trsp:revenue-type-crawl
  a skos:Concept ;
  skos:prefLabel "Crawl"@en ;
  skos:definition "Payment every time the content is crawled."@en ;
  dcterms:source <https://rslstandard.org/rsl#_3-7-payment-compensation-terms> ;
  skos:inScheme trsp:ConceptScheme .

trsp:revenue-type-ai-use
  a skos:Concept ;
  skos:prefLabel "AI Use"@en ;
  skos:definition "Payment each time the content contributes to an AI-generated output, including use in inference, grounding, or generation processes."@en ;
  dcterms:source <https://rslstandard.org/rsl#_3-7-payment-compensation-terms> ;
  skos:closeMatch <https://w3id.org/AIRO#AIUser> ;
  skos:broadMatch <https://w3id.org/AIRO#AIUser> ;
  rdfs:seeAlso <https://w3id.org/AIRO#AIUser> ;
  skos:inScheme trsp:ConceptScheme .

trsp:revenue-type-contribution
  a skos:Concept ;
  skos:prefLabel "Contribution"@en ;
  skos:definition "A good faith monetary or in-kind contribution that supports the development or maintenance of the assets, or the broader content ecosystem."@en ;
  dcterms:source <https://rslstandard.org/rsl#_3-7-payment-compensation-terms> ;
  skos:inScheme trsp:ConceptScheme .

trsp:revenue-type-contribution
  a skos:Concept ;
  skos:prefLabel "Attribution"@en ;
  skos:definition "Licensees MUST provide visible credit and a functional link to the original source."@en ;
  dcterms:source <https://rslstandard.org/rsl#_3-7-payment-compensation-terms> ;
  skos:closeMatch <http://simile.mit.edu/2003/10/ontologies/vraCore3#attribution> ;
  skos:exactMatch <http://simile.mit.edu/2003/10/ontologies/vraCore3#attribution> ;
  rdfs:seeAlso <http://simile.mit.edu/2003/10/ontologies/vraCore3#attribution> ;
  skos:inScheme trsp:ConceptScheme .
