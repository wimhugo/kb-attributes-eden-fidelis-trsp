@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

trsp:checklistEthics
  a skos:ConceptScheme ;
  skos:prefLabel "Checklist on Ethics Alignment"@en ;
  dct:title "Checklist on Ethics Alignment"@en ;
  dct:created "2026-05-03"^^xsd:date ;
  dct:modified "2026-05-03"^^xsd:date ;
  owl:versionInfo "0.1" .

trsp:ethicsClearance
  a skos:Concept ;
  skos:prefLabel "Ethics Clearance"@en ;
  skos:inScheme trsp:checklistEthics .

trsp:informedConsent
  a skos:Concept ;
  skos:prefLabel "Informed Consent"@en ;
  skos:inScheme trsp:checklistEthics .
