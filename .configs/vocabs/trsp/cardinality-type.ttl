@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

trsp:cardinality-scheme a skos:ConceptScheme ;
  dct:created "2026-04-29T00:00:00+00:00"^^xsd:datetime;
  dct:creator <https://orcid.org/0000-0002-0255-5101>;
  dct:contributor <https://orcid.org/0000-0003-1106-8441>;
  dct:description "Aggregation Types determine the mechanism for resolving multiple values associated with an attribute measurement"@en;
  dct:modified "2026-04-29T00:00:00+00:00"^^xsd:datetime;
  dct:rights <https://spdx.org/licenses/CC0-1.0>;
  dct:title "TRSP Aggregation Types"@en;
  skos:prefLabel "TRSP cardinality types"@en .
  owl:versionInfo "0.0.1"@en;
  foaf:homepage  <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

trsp:cardinality0_1
    a skos:Concept, trsp:CardinalityType ;
    skos:inScheme trsp:cardinality-scheme ;
    skos:prefLabel "0..1"@en ;
    skos:notation "0..1" ;
    skos:definition "Zero or one value permitted."@en .

trsp:cardinality1_1
    a skos:Concept, trsp:CardinalityType ;
    skos:inScheme trsp:cardinality-scheme ;
    skos:prefLabel "1..1"@en ;
    skos:notation "1..1" ;
    skos:definition "Exactly one value required."@en .

trsp:cardinality0_n
    a skos:Concept, trsp:CardinalityType ;
    skos:inScheme trsp:cardinality-scheme ;
    skos:prefLabel "0..n"@en ;
    skos:notation "0..n" ;
    skos:definition "Zero or more values permitted."@en .

trsp:cardinality1_n
    a skos:Concept, trsp:CardinalityType ;
    skos:inScheme trsp:cardinality-scheme ;
    skos:prefLabel "1..n"@en ;
    skos:notation "1..n" ;
    skos:definition "One or more values required."@en .
