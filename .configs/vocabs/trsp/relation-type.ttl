@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

trsp:relation-type-scheme a skos:ConceptScheme;
  dct:created "2026-04-29T00:00:00+00:00"^^xsd:datetime;
  dct:creator <https://orcid.org/0000-0002-0255-5101>;
  dct:contributor <https://orcid.org/0000-0003-1106-8441>;
  dct:description "Relation Types distinguish the type of relation between Attributes and Profiles"@en;
  dct:modified "2026-04-29T00:00:00+00:00"^^xsd:datetime;
  dct:rights <https://spdx.org/licenses/CC0-1.0>;
  dct:title "TRSP Relation Types"@en;
  skos:prefLabel "TRSP Relation Types"@en;
  owl:versionInfo "0.0.1"@en;
  foaf:homepage  <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

trsp:relationTypeAssertion a skos:Concept, trsp:ProfileType ;
    dct:created "2026-04-29T00:00:00+00:00"^^xsd:datetime;
    dct:creator <https://orcid.org/0000-0002-0255-5101>;
    skos:prefLabel "Assertion Type"@en ;
    dct:description "The relation asserts a value/ measurement for a property or a relationship to a profile"@en;
    skos:inScheme trsp:relation-type-scheme .

trsp:relationTypeAnnotation a skos:Concept, trsp:ProfileType ;
    dct:created "2026-04-29T00:00:00+00:00"^^xsd:datetime;
    dct:creator <https://orcid.org/0000-0002-0255-5101>;
    skos:prefLabel "Annotation Type"@en ;
    dct:description "The relation represents an annotation with a web reference to substantiate a claim"@en;
    skos:inScheme trsp:profile-type-scheme .

