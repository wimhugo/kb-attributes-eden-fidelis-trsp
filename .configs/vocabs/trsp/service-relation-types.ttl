############################################################################################################################
#  Service Relation Types
#  This describes the relation between a Service and a Repository
#  A Repository MAY use one or more Services, and a Repository MAY offer one or more Services
############################################################################################################################

@prefix trsp: <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

trsp:service-relation-scheme a skos:ConceptScheme ;
    dct:created "2026-04-29T00:00:00+00:00"^^xsd:datetime;
    dct:creator <https://orcid.org/0000-0002-0255-5101>;
    dct:contributor <https://orcid.org/0000-0003-1106-8441>;
    dct:description "Service Relation Types identify the Services offered and consumed by a Repository "@en;
    dct:modified "2026-04-29T00:00:00+00:00"^^xsd:datetime;
    dct:rights <https://spdx.org/licenses/CC0-1.0>;
    dct:title "TRSP Service Relation Types"@en;
    skos:prefLabel "Service relation types"@en .
    owl:versionInfo "0.0.1"@en;
    foaf:homepage  <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

trsp:offeredByRepository a skos:Concept ;
    dct:created "2026-04-29T00:00:00+00:00"^^xsd:datetime;
    dct:creator <https://orcid.org/0000-0002-0255-5101>;
    skos:prefLabel "Service offered by repository"@en ;
    skos:definition "Service is offered by a repository to users, for example an OAI-PMH endpoint or a file metadata service"@en ;
    skos:inScheme trsp:service-relation-scheme .

trsp:usedByRepository a skos:Concept ;
    dct:created "2026-04-29T00:00:00+00:00"^^xsd:datetime;
    dct:creator <https://orcid.org/0000-0002-0255-5101>;
    skos:prefLabel "Service used by repository"@en ;
    skos:definition "An external Service is used by a repository to users, for example a file conversion or metadata crosswalks service"@en ;
    skos:inScheme trsp:service-relation-scheme .
