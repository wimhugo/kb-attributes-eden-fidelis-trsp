@prefix trsp:   <https://example.org/trsp/> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix schema: <https://schema.org/> .
@prefix dcat:   <http://www.w3.org/ns/dcat#> .

##Attribute Definition
trsp:att.TEMPLATE
    a trsp:Attribute, skos:Concept, schema:DefinedTerm ;
    schema:name ""@en ;
    skos:prefLabel ""@en ;
    skos:altLabel ""@en ;
    schema:description ""@en ;
    schema:category ""@en ;
    skos:broader ""@en ;
    dcat:keyword ""@en ;
    trsp:hasMeasurementType <> ; ## trsp:measurement-type-scheme
    trsp:benchmark ""@en ;
    trsp:cardinalityCode <> ; ## trsp:cardinality-scheme
    ## External Identifiers
    trsp:hasExternalIdentifier [
        a trsp:ExternalIdentifier ;
        trsp:relationType <> ; ## trsp:relation-type-scheme
        trsp:identifierIri <> ;
        trsp:identifierUsage trsp:defaultUsage .
        ] ;
    ## Profile Assertions
    trsp:hasApplicableProfileAssertion [
        a trsp:ProfileAssertion ;
        trsp:relationType trsp:includeInProfile ;
        trsp:object trsp:profile.TEMPLATE ;
        trsp:profileClass trsp:profileTypeRepository ;
        trsp:profileAttributeIRI trsp:att.TEMPLATE ;
        trsp:profileAttributeAggregationType trsp:aggregationSingleSelect ;
    ] .
