@prefix trsp: <https://example.org/trsp/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdft: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

#################################
# Attribute shape
#################################

trsp:AttributeShape
    a sh:NodeShape ;
    sh:targetClass trsp:Attribute ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
    ] .

#################################
# Repository shape
#################################

trsp:RepositoryShape
    a sh:NodeShape ;
    sh:targetClass trsp:Repository ;
    sh:property [
        sh:path dct:title ;
        sh:minCount 1 ;
    ] .

#################################
# Service shape
#################################

trsp:ServiceShape
    a sh:NodeShape ;
    sh:targetClass trsp:Service ;
    sh:property [
        sh:path dct:title ;
        sh:minCount 1 ;
    ] .

#################################
# Additional Requirements
#################################

# Fixing SKOS concepts
# Adding skos:topConceptOf for root top concepts
# Ensuring all concepts have a prefLabel

trsp:Attribute
    a skos:Concept ;
    skos:prefLabel "Attribute"@en ;
    skos:broader trsp:ConceptScheme .

trsp:Repository
    a skos:Concept ;
    skos:prefLabel "Repository"@en ;
    skos:broader trsp:ConceptScheme .

trsp:Service
    a skos:Concept ;
    skos:prefLabel "Service"@en ;
    skos:broader trsp:ConceptScheme .

trsp:ConceptScheme
    a skos:ConceptScheme ;
    skos:hasTopConcept trsp:Attribute ;
    skos:hasTopConcept trsp:Repository ;
    skos:hasTopConcept trsp:Service ;
    skos:prefLabel "Concept Scheme"@en .

# To disambiguate duplicate labels
trsp:Attribute skos:prefLabel "Attribute (alternative)"@en .
trsp:Repository skos:prefLabel "Repository (alternative)"@en .
trsp:Service skos:prefLabel "Service (alternative)"@en .