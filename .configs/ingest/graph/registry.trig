                                      dcat:service           <https://lida.dataverse.lt/api/search?q=%2A> , <https://lida.dataverse.lt/oai?verb=Identify> , <https://lida.dataverse.lt/dvn/api/data-deposit/v1.1/swordv2/service-document>;
                                      prov:hadPrimarySource  "eden://harvester/re3data/https://lida.dataverse.lt/" , "eden://harvester/meta_tags/https://lida.dataverse.lt/" , "eden://harvester/fairsharing/https://lida.dataverse.lt/"
