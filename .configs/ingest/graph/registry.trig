<eden://harvester/harmonized/https://modelarchive.org/> {
    <eden://harvester/harmonized/https://modelarchive.org/>
            a                       dcat:CatalogRecord;
            prov:wasAssociatedWith  [ a           prov:SoftwareAgent;
                                      prov:label  "EDEN Catalog Service Harvester"
                                    ];
            prov:wasGeneratedBy     [ a          prov:Activity;
                                      prov:name  "Metadata harmonizing activity"
                                    ];
            foaf:primaryTopic       [ a                      dcat:Catalog , foaf:Project;
                                      dct:conformsTo         <https://modelarchive.org/account> , <https://creativecommons.org/licenses/by/4.0/>;
                                      dct:contactPoint       [ a               vcard:Kind;
                                                               vcard:hasEmail  "torsten.schwede@unibas.ch"
                                                             ];
                                      dct:description        "ModelArchive is the archive for structural models which are not based on experimental data and complements the PDB archive for experimental structures and PDB-Dev for integrative structures. The ModelArchive is being developed following the \"Workshop on Applications of Protein Models in Biomedical Research\" held at the University of California, San Francisco in July 2008 for applications of protein models in biomedical research. ModelArchive is a repository for depositions of computed models of macromolecular structures which are not based on experimental data. The models can consist of any combination of proteins, RNA, DNA, or carbohydrates and include small molecules bound to them. Deposited models are findable, accessible, interoperable and reusable. Depositions are assigned a DOI to be included in manuscripts for which the model was generated.";
                                      dct:identifier         "https://modelarchive.org/" , "10.25504/FAIRsharing.tpqndj" , "urn:uuid:f5378897-0353-47d5-83a3-7a859793365b";
                                      dct:license            "https://creativecommons.org/licenses/by/4.0/";
                                      dct:publisher          [ a              foaf:Agent;
                                                               foaf:homepage  "https://sib.swiss";
                                                               foaf:name      "SIB Swiss Institute of Bioinformatics"
                                                             ];
                                      dct:publisher          [ a              foaf:Agent;
                                                               foaf:homepage  "https://www.biozentrum.unibas.ch";
                                                               foaf:name      "Biozentrum - University of Basel"
                                                             ];
                                      dct:title              "ModelArchive";
                                      dct:type               "dcat:Catalog" , "foaf:Project";
                                      dcat:keyword           "structural biology" , "bioinformatics";
                                      prov:hadPrimarySource  "eden://harvester/embedded_jsonld/https://modelarchive.org/" , "eden://harvester/meta_tags/https://modelarchive.org/" , "eden://harvester/fairsharing/https://modelarchive.org/"
                                    ] .
    
