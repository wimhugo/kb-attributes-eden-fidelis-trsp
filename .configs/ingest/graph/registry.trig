            dct:publisher     [ a              foaf:Agent;
                                vcard:country  "Austria";
                                foaf:homepage  "https://www.plus.ac.at/?lang=en";
                                foaf:name      "University of Salzburg"
                              ];
            dct:title         "Austrian NeuroCloud";
            dct:type          "r3d:Repository";
