                                                               foaf:homepage  "https://www.cnrs.fr/fr";
                                                               foaf:name      "Ministry of Higher Education and Research, National Center for Scientific Research"
                                                             ];
                                      dct:publisher          [ a              foaf:Agent;
                                                               vcard:country  "France";
                                                               foaf:homepage  "https://data.progedo.fr/";
                                                               foaf:name      "Quetelet Progedo"
                                                             ];
