            a                       dcat:CatalogRecord;
            dct:issued              "2026-04-22T11:59:13";
            prov:wasAssociatedWith  [ a           prov:SoftwareAgent;
                                      prov:label  "EDEN Catalog Service Harvester"
                                    ];
            prov:wasGeneratedBy     <eden://harvester/fairsharing>;
            foaf:primaryTopic       <https://aussda.at/> .
    
    <https://aussda.at/>
            a                 dcat:Catalog , foaf:Project;
            dct:conformsTo    <https://aussda.at/fileadmin/user_upload/p_aussda/Documents/Preservation_Plan_v1_0.pdf> , <https://aussda.at/en/faq-downloads/faq/> , <https://aussda.at/fileadmin/user_upload/p_aussda/Documents/Template_report_on_data_checks.xlsx>;
            dct:contactPoint  [ a               vcard:Kind;
                                vcard:hasEmail  "info@aussda.at"
                              ];
            dct:description   "AUSSDA - The Austrian Social Science Data Archive is a certified, national research infrastructure for the social science community. We offer sustainable and easy-to-use services in the field of digital archiving and preservation. The main beneficiaries are researchers, students, educational institutions and media professionals.\n\nWe implement international standards to make research data findable, accessible, interoperable and reusable according to the FAIR principles. AUSSDA supports the open science movement to maximize the potential for data reuse. We stand for integrity in archiving and advocate for compliance with data protection and ethical principles in research data management.\n\nAUSSDA represents Austria as a national service provider in CESSDA ERIC, has locations at the University of Vienna and the WU Wien and at the universities of Graz, Linz, Innsbruck, Krems, Klagenfurt and Salzburg as well as at the OeAW (Austrian Academy of Sciences) and works within a network of national and international partners.";
            dct:identifier    "https://www.re3data.org/repository/r3d100010483" , "10.25504/FAIRsharing.RJ3PDJ";
            dct:license       "https://aussda.at/en/contracts-and-licenses/";
            dct:publisher     [ a          foaf:Agent;
                                foaf:name  "AUSSDA - The Austrian Social Science Data Archive"
                              ];
            dct:title         "AUSSDA - The Austrian Social Science Data Archive ";
            dct:type          "fairsharing:repository";
            dcat:keyword      "Humanities and Social Science" , "Social Science" , "Education Science" , "Political Science" , "Communication Science" , "Public Health" , "Data Governance" , "Jurisprudence" , "Media Studies" , "Data Management" , "Demographics" , "Social and Behavioural Science" , "Economics" , "Data Quality" , "Cultural Studies" , "Data Protection" , "Psychology" , "Database Management" .
    
    <https://aussda.at/fileadmin/user_upload/p_aussda/Documents/Preservation_Plan_v1_0.pdf>
            a          <premis:PreservationPolicy> , dct:Policy;
            dct:title  "Preservation Plan" .
    
    <https://aussda.at/en/faq-downloads/faq/>
            a          <ex:SustainabilityPolicy> , dct:Policy;
            dct:title  "AUSSDA is an archive for the long-term storage of research data and has therefore taken precautions to secure data for as long as possible - for the lifetime of the archive and beyond. The University of Vienna, as coordinator of AUSSDA, has committed itself in its RDM policy to maintaining the infrastructure for research data management and ensures a long-term perspective. Storage for at least 10 years, which is usually regarded as good scientific practice and required by funding bodies, is thus guaranteed. In addition, AUSSDA is a CoreTrustSeal-certified and thus trustworthy repository - a criterion that funding bodies explicitly recommend when selecting a repository (see, for example, the RDM and funding criteria of the FWF or Horizon Europe)." .
    
    <https://aussda.at/fileadmin/user_upload/p_aussda/Documents/Template_report_on_data_checks.xlsx>
            a       <ex:DepositionPolicy> , dct:Policy .
}

