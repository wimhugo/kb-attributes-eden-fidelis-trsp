<eden://harvester/harmonized/https://www.cellosaurus.org/> {
    <eden://harvester/harmonized/https://www.cellosaurus.org/>
            a                       dcat:CatalogRecord;
            prov:wasAssociatedWith  [ a           prov:SoftwareAgent;
                                      prov:label  "EDEN Catalog Service Harvester"
                                    ];
            prov:wasGeneratedBy     [ a          prov:Activity;
                                      prov:name  "Metadata harmonizing activity"
                                    ];
            foaf:primaryTopic       [ a                      dcat:Catalog , foaf:Project;
                                      dct:contactPoint       [ a               vcard:Kind;
                                                               vcard:hasEmail  "cellosaurus@sib.swiss";
                                                               vcard:url       "https://www.cellosaurus.org/contact"
                                                             ];
                                      dct:description        "The Cellosaurus is a knowledge resource on cell lines. It attempts to describe all cell lines used in biomedical research. Its scope includes: Immortalized cell lines, Naturally immortal cell lines (example: stem cell lines), Finite life cell lines when those are distributed and used widely, Vertebrate cell line with an emphasis on human, mouse and rat cell lines, Invertebrate (insects and ticks) cell lines. Its scope does not include: Primary cell lines (with the exception of the finite life cell lines described above), Plant cell lines.  Cellosaurus was initiated to be used as a cell line controlled vocabulary in the context of the neXtProt knowledgebase, but it quickly become apparent that there was a need for a cell line knowledge resource that would serve the needs of individual researchers, cell line distributors and bioinformatic resources. This leads to an increase of the scope and depth of the content of the Cellosaurus. The Cellosaurus is a participant of the Resource Identification Initiative and contributes actively to the work of the International Cell Line Authentication Committee (ICLAC). It is a Global Core Biodata Resource, an ELIXIR Core Data Resource and an IRDiRC Recognized Resource.";
                                      dct:identifier         "10.25504/FAIRsharing.hkk309" , "urn:uuid:c6d53a5a-5f75-4685-8d53-75b08f416d5d" , "https://www.cellosaurus.org/" , "SCR_013869" , "r3d100013293" , "https://www.re3data.org/repository/r3d100013293";
                                      dct:license            "http://creativecommons.org/";
                                      dct:publisher          [ a              foaf:Agent;
                                                               vcard:country  "Switzerland";
                                                               foaf:homepage  "https://www.sib.swiss/amos-bairoch-lydie-lane-group";
                                                               foaf:name      "Swiss Institute of Bioinformatics, Computer and Laboratory Investigation of Proteins of Human Origin Group"
                                                             ];
                                      dct:title              "Cellosaurus";
                                      dct:type               "dcat:Catalog" , "foaf:Project";
                                      dcat:keyword           "embryonic stem cell" , "serum/protein free medium cell lines" , "fish cell lines" , "covid-19" , "misidentification" , "patented cell lines" , "biology" , "amphibian cell lines" , "cell line" , "str" , "sequence variation" , "basic biological and medical research" , "cell biology" , "genetic disease" , "vaccine production cell lines" , "bird cell lines" , "crispr/cas9" , "induced pluripotent stem cell" , "transformation" , "contamination" , "bat cell lines" , "transduction" , "authentication" , "resistance to drugs" , "hybridoma" , "cancer" , "life sciences" , "insect cell lines" , "knockout" , "reptilian cell lines" , "tick cell lines" , "life science" , "endangered species/breed cell lines" , "short tandem repeat";
