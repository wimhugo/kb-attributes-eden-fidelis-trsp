<eden://harvester/re3data/https://pangaea.de/> {
    <https://www.pangaea.de/about/preservation.php>
            a          dct:Policy;
            dct:title  "PANGAEA preservation policy" .
    
    <https://pangaea.de/>
            a                 dcat:Catalog , foaf:Project;
            dct:conformsTo    <https://www.pangaea.de/about/preservation.php> , <https://pangaea.de/about/terms.php>;
