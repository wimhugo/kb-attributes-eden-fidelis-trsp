                                foaf:name  "European Bioinformatics Institute (EMBL-EBI), Wellcome Genome Campus, Hinxton, Cambridgeshire, UK"
                              ];
            dct:title         "PRoteomics IDEntifications database";
            dct:type          "fairsharing:repository";
            dcat:keyword      "Metaproteomics" , "Proteomics" , "Natural Science" , "Life Science" , "Environmental Science" .
