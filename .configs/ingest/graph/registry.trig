                                                               vcard:country  "United States of America";
                                                               foaf:homepage  "https://www.nigms.nih.gov/";
                                                               foaf:name      "NIH National Institute of General Medical Sciences"
                                                             ];
                                      dct:publisher          [ a              foaf:Agent;
                                                               vcard:country  "United States of America";
                                                               foaf:homepage  "https://www.sanger.ac.uk/";
                                                               foaf:name      "Wellcome Trust Sanger Institute"
                                                             ];
                                      dct:title              "LIPID MAPS";
                                      dct:type               "dcat:Catalog" , "foaf:Project";
