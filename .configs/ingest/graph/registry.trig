<eden://harvester/fairsharing/https://aussda.at/> {
    <eden://harvester/fairsharing>
            a                   prov:Activity;
            prov:name           "FAIRsharing.org Registry Harvesting";
            prov:startedAtTime  "2026-04-22T11:59:13" .
    
