                                vcard:country  "Austria";
                                foaf:name      "Austrian NeuroCloud"
                              ];
            dct:title         "Austrian NeuroCloud";
            dct:type          "schema:DataCatalog" , "dcat:Catalog" , "foaf:Project" , "schema:Project";
