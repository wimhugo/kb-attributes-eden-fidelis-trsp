                                                             ];
                                      dct:publisher          [ a              foaf:Agent;
                                                               vcard:country  "EEC";
                                                               foaf:homepage  "https://www.cessda.eu/";
                                                               foaf:name      "Council of European Social Science Data European Research Infrastructure Consortium"
                                                             ];
                                      dct:title              "Quetelet-Progedo";
                                      dct:type               "dcat:Catalog" , "foaf:Project";
                                      dcat:keyword           "social sciences" , "surveys" , "humanities and social sciences" , "census data" , "socio-political" , "humanities and social science" , "social science" , "social and behavioural sciences";
