                                foaf:homepage  "https://www.nigms.nih.gov/";
                                foaf:name      "NIH National Institute of General Medical Sciences"
                              ];
            dct:publisher     [ a              foaf:Agent;
                                vcard:country  "United States of America";
                                foaf:homepage  "https://www.sanger.ac.uk/";
                                foaf:name      "Wellcome Trust Sanger Institute"
                              ];
            dct:title         "LIPID MAPS";
            dct:type          "r3d:Repository";
            dcat:keyword      "pathways" , "lipid-based disease" , "metabolite" , "lipid metabolism" , "Basic Biological and Medical Research" , "Lipid Classification System" , "Endocrinology, Diabetology" , "Life Sciences" , "Medicine" , "mass spectrometry" , "molecule" , "Cell Biology" , "metabolomics" , "lipids" , "biochemistry" , "Biology" , "pathway" , "mammalian cells";
