<https://www.crossda.hr/>
  a dcat:Catalog, foaf:Project ;
  dct:title "Croatian Social Science Data Archive" ;
  dct:title "Croatian Social Science Data Archive" ;
  dct:title "I4NG: Next Level Europe: Educational and employment opportunities for young people in Europe" ;
