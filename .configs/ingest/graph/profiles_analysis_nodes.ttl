<https://data.4tu.nl/>
  a dcat:Catalog, foaf:Project ;
  dct:title "4TU.ResearchData" ;
  dct:title "4TU.ResearchData | science.engineering.design" ;
  dct:identifier "https://data.4tu.nl/" ;
  dct:identifier "10.25504/FAIRsharing.zcveaz" ;
