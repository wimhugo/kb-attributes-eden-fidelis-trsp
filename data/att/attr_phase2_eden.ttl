  a skos:Concept ;
  skos:prefLabel "Justification for restriction"@en ;
  skos:description "Metadata includes justification for the applied restriction"@en ;
  schema:category "Interoperability|Legal Interoperability|Restriction Handling and Compliance|Documentation of applicable restrictions" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000b9
  a skos:Concept ;
  skos:prefLabel "Restriction Policy and Legal Guidance"@en ;
  skos:description "URI to restriction policies and or legal guidance"@en ;
  schema:category "Interoperability|Legal Interoperability|Restriction Handling and Compliance|Documentation of applicable restrictions" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000bb
  a skos:Concept ;
  skos:prefLabel "Provides documentation URI"@en ;
  skos:description "Repositories and services should align with applicable legal frameworks, including GDPR and national open data laws, to ensure lawful access, storage, and sharing."@en ;
  schema:category "Rights & Ethics|Copyright & Law, Institutional Policy|Policy and Regulatory Alignment|Alignment with EU and national data policies" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000bf
  a skos:Concept ;
  skos:prefLabel "License Mandate Metadata"@en ;
  skos:description "Metadata includes license mandate information"@en ;
  schema:category "Rights & Ethics|Copyright & Law, Institutional Policy|Policy and Regulatory Alignment|Evaluation of license mandates at different levels" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

