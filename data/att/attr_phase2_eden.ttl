  a skos:Concept ;
  skos:prefLabel "maDMP Availability and Linking"@en ;
  skos:description "maDMP is available and linked"@en ;
  schema:category "Quality|Contextual Data Quality|Authenticity and Originality|Research Origin Verified" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000d0
  a skos:Concept ;
  skos:prefLabel "Documentation link available"@en ;
  skos:description "Repositories can inspect provenance information to confirm the authenticity of work submitted for publication"@en ;
  schema:category "Quality|Contextual Data Quality|Authenticity and Originality|Provenance" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000d7
  a skos:Concept ;
  skos:prefLabel "Access policy available - GDPR"@en ;
  skos:description "The repository verifies whether personal data is included in the deposit, and if so, follows a procedure to determine the level of protection required and implements it"@en ;
  schema:category "Quality|Contextual Data Quality|Legal and Contractual Aspects|GDPR" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000d9
  a skos:Concept ;
  skos:prefLabel "Defines access policy - GDPR"@en ;
  skos:description "The repository verifies whether personal data is included in the deposit, and if so, follows a procedure to determine the level of protection required and implements it"@en ;
  schema:category "Quality|Contextual Data Quality|Legal and Contractual Aspects|GDPR" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000da
  a skos:Concept ;
  skos:prefLabel "Attribute support available - GDPR"@en ;
  skos:description "The repository verifies whether personal data is included in the deposit, and if so, follows a procedure to determine the level of protection required and implements it"@en ;
  schema:category "Quality|Contextual Data Quality|Legal and Contractual Aspects|GDPR" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000db
  a skos:Concept ;
  skos:prefLabel "Access Rights Metadata"@en ;
  skos:description "Metadata standards & vocabulary used to explicitly indicate the rights"@en ;
  schema:category "Rights & Ethics|Legal Interoperability|Unclear permissions|Right statement standardisation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000e3
  a skos:Concept ;
  skos:prefLabel "Metadata available"@en ;
  skos:description "The repository uses commonly accepted machine readable standard terms (or URIs) to indicate licenses"@en ;
  schema:category "Rights & Ethics|Licensing|Licensing conflicts|License standarisation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000e4
  a skos:Concept ;
  skos:prefLabel "Defines access license"@en ;
  skos:description "The repository uses commonly accepted machine readable standard terms (or URIs) to indicate licenses"@en ;
  schema:category "Rights & Ethics|Licensing|Licensing conflicts|License standarisation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000e6
  a skos:Concept ;
  skos:prefLabel "Standardized open licenses used - guidance"@en ;
  skos:description "The repository provides user guidance to select the most appropriate license"@en ;
  schema:category "Rights & Ethics|Licensing|Licensing conflicts|License guidance" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000e7
  a skos:Concept ;
  skos:prefLabel "Attribute support available - Licence provision"@en ;
  skos:description "The repository maintains a registry or list of accepted licenses"@en ;
  schema:category "Rights & Ethics|Licensing|Licensing conflicts|Licence provision" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000e8
  a skos:Concept ;
  skos:prefLabel "Licence stewardship"@en ;
  skos:description "The repository regularly checks assigned licenses and has workflows in place to replace outdated or invalid licenses in a legally compliant manner."@en ;
  schema:category "Rights & Ethics|Licensing|Licensing conflicts|Licence stewardship" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000e9
  a skos:Concept ;
  skos:prefLabel "Explicit policy indication"@en ;
  skos:description "The repository exposes policies in a standardised way."@en ;
  schema:category "Rights & Ethics|Institutional Policy|Inconsistent policies|Policy standardisation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000ea
  a skos:Concept ;
  skos:prefLabel "Defines access policy vocabulary"@en ;
  skos:description "The repository uses a controlled vocabulary to indicate the policy type of its policy documents."@en ;
  schema:category "Rights & Ethics|Institutional Policy|Inconsistent policies|Policy (type) provision" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000ed
  a skos:Concept ;
  skos:prefLabel "Attribute support available - Legal clearance"@en ;
  skos:description "The repository provides mechanisms and tools to assess the legal compliance of its assets."@en ;
  schema:category "Rights & Ethics|Copyright & Law|Legal uncertainty|Legal clearance" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000f0
  a skos:Concept ;
  skos:prefLabel "Attribute support available - Ethics clearance"@en ;
  skos:description "The repository has tools to perform ethical assessments"@en ;
  schema:category "Rights & Ethics|Ethical Constraints|Ethics Considerations|Ethics Clearance" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000f1
  a skos:Concept ;
  skos:prefLabel "Documentation link available - Consent"@en ;
  skos:description "The repository manages its users' contracts and consents and assigns them to individual digital objects as necessary such as preservation agreements etc."@en ;
  schema:category "Rights & Ethics|Contract / Preservation Agreement, Technical Interoperability, Semantic Interoperability, Legal Interoperability, Contextual Data Quality, Metadata Quality, Technical Data Quality, Copyright & Law, Licensing|Documentation gaps|Contract and consent management" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000f3
  a skos:Concept ;
  skos:prefLabel "Requires specific metadata formats"@en ;
  skos:description "The repository is able to show the extent to which its AIPs fulfil the requirements of the OAIS Information model."@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of well defined semantics for AIPs|Evaluaton of AIPs against the semantics of the OAIS Information Model" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000f4
  a skos:Concept ;
  skos:prefLabel "AIP Completeness Assessment"@en ;
  skos:description "AIPs from a repository can be tested and assessed in a standardised way for their completeness."@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of well defined semantics for AIPs|Evaluaton of AIPs against the semantics of the OAIS Information Model" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000ff
  a skos:Concept ;
  skos:prefLabel "Attribute support available - FAIR assessment aggregated score"@en ;
  skos:description "The curator, or the system includes a FAIR score in the deposit and publishes them on different levels."@en ;
  schema:category "Quality|Metadata Quality|Automated FAIR Metadata assessment|FAIR assessment aggregated score" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000107
  a skos:Concept ;
  skos:prefLabel "Provides metadata schema mappings"@en ;
  skos:description "Metadata needs to conform to metadata standards or schemas relevant to the domain or general best practice. Repositories should declare which metadata schema(s) they use and support interoperability via mappings."@en ;
  schema:category "Quality|Metadata Quality|Metadata Completeness|Metadata Standards Alignment" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00010b
  a skos:Concept ;
  skos:prefLabel "Multilingual Metadata Support"@en ;
  skos:description "A repository supports metadata in multiple languages to broaden accessibility."@en ;
  schema:category "Quality|Metadata Quality|Multilingual Metadata|Language Localization and indexation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00010e
  a skos:Concept ;
  skos:prefLabel "Supports provenance metadata"@en ;
  skos:description "Metadata holds sufficient context for reuse of the data, such as provenance information and usage license."@en ;
  schema:category "Quality|Contextual Data Quality|Authenticity and Originality|Provenance" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00010f
  a skos:Concept ;
  skos:prefLabel "Technical Metadata Extraction"@en ;
  skos:description "The repository or service is able to extract relevant technical metadata from files based on the defined significant properties."@en ;
  schema:category "Quality|Technical Data Quality|Lack documented properties of files in a repository|Technical metadata extraction" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000111
  a skos:Concept ;
  skos:prefLabel "Machine-Actionable File Format Templates"@en ;
  skos:description "Machine-actionable template for each file format supported"@en ;
  schema:category "Quality|Technical Data Quality|Lack documented properties of files in a repository|Significant properties definition" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000114
  a skos:Concept ;
  skos:prefLabel "File Format Granularity Specification"@en ;
  skos:description "Indication of granularity for each file format (file format version, profiles)"@en ;
  schema:category "Quality|Technical Data Quality|A repository does not know if files it preserves are well-formed and valid|File format identification" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000115
  a skos:Concept ;
  skos:prefLabel "Multi-Tool File Format Integration"@en ;
  skos:description "Provides a possible integration of several different tools for different file formats"@en ;
  schema:category "Quality|Technical Data Quality|A repository does not know if files it preserves are well-formed and valid|File format identification" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
