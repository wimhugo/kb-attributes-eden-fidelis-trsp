  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000037
  a skos:Concept ;
  skos:prefLabel "PID Policy"@en ;
  skos:description "Repository publishes its policy for PID?"@en ;
  schema:category "Interoperability|Technical Interoperability|Persistent Identifier (PID) Diversity and Policy Gaps|Cross-community PID harmonisation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000038
  a skos:Concept ;
  skos:prefLabel "Use of PID standards"@en ;
  skos:description "Publishes which persistent identifier standards it supports in a machine-readable way"@en ;
  schema:category "Interoperability|Technical Interoperability|Persistent Identifier (PID) Diversity and Policy Gaps|Cross-community PID harmonisation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00003a
  a skos:Concept ;
  skos:prefLabel "PID Metadata machine readable"@en ;
  skos:description "Is PID metadata exposed in a machine-readable format?"@en ;
  schema:category "Interoperability|Technical Interoperability|Persistent Identifier (PID) Diversity and Policy Gaps|Cross-community PID harmonisation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00003b
  a skos:Concept ;
  skos:prefLabel "External objects"@en ;
  skos:description "Can a PID be linked to objects in another domain?"@en ;
  schema:category "Interoperability|Technical Interoperability|Persistent Identifier (PID) Diversity and Policy Gaps|Cross-community PID harmonisation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00003d
  a skos:Concept ;
  skos:prefLabel "Resolvable PIDs over HTTPS"@en ;
  skos:description "Is the PID resolvable via HTTPS?"@en ;
  schema:category "Interoperability|Technical Interoperability|Persistent Identifier (PID) Diversity and Policy Gaps|Machine-resolvable PIDs" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00003f
  a skos:Concept ;
  skos:prefLabel "PID-Based Metadata Autoresolution"@en ;
  skos:description "Does the repository have the capability to autoresolve metadata based on PIDs?"@en ;
  schema:category "Interoperability|Technical Interoperability|Persistent Identifier (PID) Diversity and Policy Gaps|Machine-resolvable PIDs" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000040
  a skos:Concept ;
  skos:prefLabel "PID Type Usage"@en ;
  skos:description "Which type of PID is used in the repository"@en ;
  schema:category "Interoperability|Technical Interoperability|Persistent Identifier (PID) Diversity and Policy Gaps|Machine-resolvable PIDs" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000044
  a skos:Concept ;
  skos:prefLabel "Structured Metadata PID Support"@en ;
  skos:description "Does the repository support PID which are connected to structured descriptive metadata?"@en ;
  schema:category "Interoperability|Technical Interoperability|Persistent Identifier (PID) Diversity and Policy Gaps|Metadata-linked identifiers" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000049
  a skos:Concept ;
  skos:prefLabel "Digital object version tracking"@en ;
  skos:description "Does the PID system track different versions of an object?"@en ;
  schema:category "Interoperability|Technical Interoperability|Persistent Identifier (PID) Diversity and Policy Gaps|Clear EOSC PID policy and lifecycle tracking" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00004d
  a skos:Concept ;
  skos:prefLabel "Defines access policy - EOSC"@en ;
  skos:description "Link to policy of assignment & reassignment and deprecation of PIDs"@en ;
  schema:category "Interoperability|Technical Interoperability|Persistent Identifier (PID) Diversity and Policy Gaps|Clear EOSC PID policy and lifecycle tracking" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000051
  a skos:Concept ;
  skos:prefLabel "Protocol documentation available"@en ;
  skos:description "Does the repository or service implement widely accepted authentication and authorisation protocols such as SAML, OpenID Connect, or OAuth2? Supporting well-established standards ensures compatibility with federated identity providers, secure machine-to-machine communication, and interoperability with EOSC’s AAI ecosystem. This also facilitates cross-service user access and integration with external infrastructures."@en ;
  schema:category "Interoperability|Technical Interoperability|Standards-Based Authentication Mechanisms|Standards Support" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000055
  a skos:Concept ;
  skos:prefLabel "Default profile"@en ;
  skos:description "Publish default metadata profile used"@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Metadata Harmonization Across Domains|Support for domain-specific metadata profiles" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000056
  a skos:Concept ;
  skos:prefLabel "Metadata profile validaton"@en ;
  skos:description "Metadata is getting validated against the profile"@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Metadata Harmonization Across Domains|Support for domain-specific metadata profiles" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000057
  a skos:Concept ;
  skos:prefLabel "Metadata profile selection"@en ;
  skos:description "Allows users to select a metadata profile"@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Metadata Harmonization Across Domains|Support for domain-specific metadata profiles" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00005a
  a skos:Concept ;
  skos:prefLabel "Crosswalks - Human readable documentation"@en ;
  skos:description "Link to an human readable documentation of the crosswalk"@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Metadata Harmonization Across Domains|Crosswalks between metadata schemas" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00005c
  a skos:Concept ;
  skos:prefLabel "Crosswalks - Schema Mapping Definitions"@en ;
  skos:description "List of schema pairs and their defined mappings"@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Metadata Harmonization Across Domains|Crosswalks between metadata schemas" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000061
  a skos:Concept ;
  skos:prefLabel "Metadata localisation"@en ;
  skos:description "Is the system able to provide the metadata in different languages to give people from different backgrounds the ability to interpret them consistently?"@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Metadata Harmonization Across Domains|Multilingual metadata support" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000062
  a skos:Concept ;
  skos:prefLabel "Supports metadata format translation"@en ;
  skos:description "Whether the system is exposing the metadata in a structured, machine-readable format aligned with FAIR principles?"@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Metadata Harmonization Across Domains|Schema.org or FAIR-compliant metadata exposure" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000063
  a skos:Concept ;
  skos:prefLabel "FAIR formats supported"@en ;
  skos:description "Supported FAIR formats, and if the system adherence to a specific metadata model or profile"@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Metadata Harmonization Across Domains|Schema.org or FAIR-compliant metadata exposure" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000067
  a skos:Concept ;
  skos:prefLabel "Semantic Artefacts - Human-readable API documentation available"@en ;
  skos:description "Does the TDR or TDA ensure that semantic artefacts used in metadata are discoverable and accessible through domain-recognized reference repositories to promote reuse, semantic consistency, and machine-actionability?"@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Metadata Harmonization Across Domains|Reference repositories for semantic artefacts" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00006b
  a skos:Concept ;
  skos:prefLabel "Machine-readable representation of terms"@en ;
  skos:description "Systems publishes URIs which resolve to useful representation of terms"@en ;
  schema:category "Interoperability|Semantic Interoperability|Inconsistent Use of Controlled Vocabularies and Ontologies|Machine-readable vocabulary linking" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00006c
  a skos:Concept ;
  skos:prefLabel "Provides machine-readable documentation - Vocabularies"@en ;
  skos:description "URI or reference to documentation of the format and vocabulary used"@en ;
  schema:category "Interoperability|Semantic Interoperability|Inconsistent Use of Controlled Vocabularies and Ontologies|Machine-readable vocabulary linking" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00006e
  a skos:Concept ;
  skos:prefLabel "Supported vocabulary & formats"@en ;
  skos:description "Whether the system has the capability to expose the controlled vocabularies and ontologies terms in such format it is machine-readable which increases metadata interpretation, reasoning and integration across systems automatically."@en ;
  schema:category "Interoperability|Semantic Interoperability|Inconsistent Use of Controlled Vocabularies and Ontologies|Machine-readable vocabulary linking" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000070
  a skos:Concept ;
  skos:prefLabel "Attribute support available - Vocabulary Harmonisation"@en ;
  skos:description "Whether the system has services available to align or map terms across different vocabularies or ontologies. These mappings ensure semantical equivalent terms for a wide variety of communities which this way can be interpreted consistently."@en ;
  schema:category "Interoperability|Semantic Interoperability|Inconsistent Use of Controlled Vocabularies and Ontologies|Vocabulary harmonisation and mapping services" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000072
  a skos:Concept ;
  skos:prefLabel "Supported mapping services"@en ;
  skos:description "Publishes a list of supported mapping services"@en ;
  schema:category "Interoperability|Semantic Interoperability|Inconsistent Use of Controlled Vocabularies and Ontologies|Vocabulary harmonisation and mapping services" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000075
  a skos:Concept ;
  skos:prefLabel "Supports multilingual vocabularies"@en ;
  skos:description "Whether the system has the capability to use or expose controlled vocabularies in multiple languages enabling different linguistic backgrounds to interpret, search and reuse metadata across domains."@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Persistent, Resolvable Identifiers for Semantic Entities|Support for multilingual vocabularies" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00007a
  a skos:Concept ;
  skos:prefLabel "Makes use of URIs to reference terms"@en ;
  skos:description "Whether the system is supporting PID for semantic terms"@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Persistent, Resolvable Identifiers for Semantic Entities|Use of PIDs for semantic terms" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00007c
  a skos:Concept ;
  skos:prefLabel "Dereferenceable identifiers"@en ;
  skos:description "Identifiers used in the metadata can be dereferenced"@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Persistent, Resolvable Identifiers for Semantic Entities|Support for semantic identifier dereferencing" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00007e
  a skos:Concept ;
  skos:prefLabel "Supports metadata formats"@en ;
  skos:description "Whether the system is aligned with well-established identifier systems for common metadata entities, which increases the discoverability and reuse."@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Persistent, Resolvable Identifiers for Semantic Entities|Alignment with recognised identifier systems" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000080
  a skos:Concept ;
  skos:prefLabel "Metadata formats - PID support"@en ;
  skos:description "Whether the system is aligned with well-established identifier systems for common metadata entities, which increases the discoverability and reuse."@en ;
  schema:category "Interoperability|Semantic Interoperability|Lack of Persistent, Resolvable Identifiers for Semantic Entities|Alignment with recognised identifier systems" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000082
  a skos:Concept ;
  skos:prefLabel "Supports ARK identifiers"@en ;
  skos:description "Whether the system supports embedded semantic annotations."@en ;
  schema:category "Interoperability|Semantic Interoperability|Fragmentation of Semantic Annotation Practices|Support for embedded semantic annotations" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000083
  a skos:Concept ;
  skos:prefLabel "External Semantic Annotation Support"@en ;
  skos:description "Whether the system supports and uses external tools or services for applying, managing and/or enriching metadata with semantic annotations. Possibly enabling decoupled annotation workflows."@en ;
  schema:category "Interoperability|Semantic Interoperability|Fragmentation of Semantic Annotation Practices|External annotation services or tools" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000086
  a skos:Concept ;
  skos:prefLabel "SLA Vocabulary"@en ;
  skos:description "Which vocabulary does the system use for defining the machine-readable SLAs"@en ;
  schema:category "Interoperability|Semantic Interoperability|Fragmentation of Semantic Annotation Practices|SLA semantics" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000088
  a skos:Concept ;
  skos:prefLabel "SLA in machine-readable format"@en ;
  skos:description "Does the system publish the SLAs in a machine-readable format?"@en ;
  schema:category "Interoperability|Semantic Interoperability|Fragmentation of Semantic Annotation Practices|SLA semantics" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00008a
  a skos:Concept ;
  skos:prefLabel "Data policy availability"@en ;
  skos:description "Whether the repository publishes its data policy in a clearly accessible location on its website, so external partners can understand the conditions and frameworks governing data access, reuse, and preservation."@en ;
  schema:category "Interoperability|Organizational Interoperability|Misalignment of Institutional Policies|Repository has a publicly accessible data policy webpage" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00008b
  a skos:Concept ;
  skos:prefLabel "Data policy is easily found"@en ;
  skos:description "The data policy is linked from metadata and/or landing pages"@en ;
  schema:category "Interoperability|Organizational Interoperability|Misalignment of Institutional Policies|Repository has a publicly accessible data policy webpage" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00008e
  a skos:Concept ;
  skos:prefLabel "Supports machine-readable policies"@en ;
  skos:description "Which format or encoding is used in the data policy"@en ;
  schema:category "Interoperability|Organizational Interoperability|Misalignment of Institutional Policies|Policy includes machine-readable terms" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000090
  a skos:Concept ;
  skos:prefLabel "Data policy includes license terms"@en ;
  skos:description "Whether the repository’s data policy is encoded in a structured, machine-readable format (e.g., JSON-LD, XML, RDF), allowing automated tools and external systems to ingest, assess, or integrate policy information."@en ;
  schema:category "Interoperability|Organizational Interoperability|Misalignment of Institutional Policies|Policy includes machine-readable terms" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000091
  a skos:Concept ;
  skos:prefLabel "Policy versioning"@en ;
  skos:description "Whether the repository maintains and displays version history of its data policy, enabling traceability and clarity over policy changes for users and collaborators."@en ;
  schema:category "Interoperability|Organizational Interoperability|Misalignment of Institutional Policies|Policy includes versioning information" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000093
  a skos:Concept ;
  skos:prefLabel "Changelog or revision history"@en ;
  skos:description "A changelog or revision history is maintained"@en ;
  schema:category "Interoperability|Organizational Interoperability|Misalignment of Institutional Policies|Policy includes versioning information" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000097
  a skos:Concept ;
  skos:prefLabel "Persistent Identifier and Versioning Consistency"@en ;
  skos:description "Data deposits are linked to persistent identifiers and versioned consistently"@en ;
  schema:category "Interoperability|Organizational Interoperability|Inconsistent Service Workflows|Standardised Data Deposit Process" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000098
  a skos:Concept ;
  skos:prefLabel "Provides an API"@en ;
  skos:description "Whether the system supports a harmonised, community-aligned workflow for data publication and deposit. This includes ensuring that data providers follow agreed protocols for metadata generation, format selection, validation, and submission. The standardisation of deposit workflows fosters interoperability, simplifies reuse, and ensures consistent metadata quality across domains."@en ;
  schema:category "Interoperability|Organizational Interoperability|Inconsistent Service Workflows|Standardised Data Deposit Process" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00009e
  a skos:Concept ;
  skos:prefLabel "Supports persistent identifiers for curation roles"@en ;
  skos:description "Roles are linked to persistent identifiers"@en ;
  schema:category "Interoperability|Organizational Interoperability|Undefined Roles and Responsibilities|Role Metadata in Deposit and Curation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00009f
  a skos:Concept ;
  skos:prefLabel "Allowed documentation URI provided"@en ;
  skos:description "Whether systems capture and expose metadata about individual and organizational roles involved in the deposit, curation, maintenance, and management of digital objects. This includes identifying roles such as data steward, curator, depositor, reviewer, or administrator."@en ;
  schema:category "Interoperability|Organizational Interoperability|Undefined Roles and Responsibilities|Role Metadata in Deposit and Curation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000a2
  a skos:Concept ;
  skos:prefLabel "Support is available and integrated"@en ;
  skos:description "Whether the system provides clear, user-friendly pathways for users to access, understand, and effectively use its services, particularly in cross-disciplinary or multi-platform research environments. This includes the availability of comprehensive documentation, tutorials, help interfaces, and support services that lower the barrier to entry and promote effective onboarding. Accessibility also refers to the clarity of service offerings, consistency in interfaces, and ease of locating and using relevant resources."@en ;
  schema:category "Interoperability|Organizational Interoperability|Lack of User-Centric Service Design|Accessibility and Support Documentation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000a3
  a skos:Concept ;
  skos:prefLabel "Documentation provided"@en ;
  skos:description "Whether the system provides clear, user-friendly pathways for users to access, understand, and effectively use its services, particularly in cross-disciplinary or multi-platform research environments. This includes the availability of comprehensive documentation, tutorials, help interfaces, and support services that lower the barrier to entry and promote effective onboarding. Accessibility also refers to the clarity of service offerings, consistency in interfaces, and ease of locating and using relevant resources."@en ;
  schema:category "Interoperability|Organizational Interoperability|Lack of User-Centric Service Design|Accessibility and Support Documentation" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

