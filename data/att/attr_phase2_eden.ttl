  a skos:Concept ;
  skos:prefLabel "Depositor Guidance Service"@en ;
  skos:description "Guidance service for depositors is available to guide them to the most appropriate repository"@en ;
  schema:category "Quality|Contextual Data Quality|Applicability and Alignment|Alignment" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000c8
  a skos:Concept ;
  skos:prefLabel "Submission Policy Alignment Verification"@en ;
  skos:description "Policy or guidance alignment is verified for submissions"@en ;
  schema:category "Quality|Contextual Data Quality|Applicability and Alignment|Alignment" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000cd
  a skos:Concept ;
  skos:prefLabel "Research Submission Verification"@en ;
  skos:description "The repository verifies that the submission was made by a researcher or someone making a deposit in a research context, and that it is a dataset associated with original research"@en ;
  schema:category "Quality|Contextual Data Quality|Authenticity and Originality|Research Origin Verified" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

