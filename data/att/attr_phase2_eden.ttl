  a skos:Concept ;
  skos:prefLabel "Access policy exposed"@en ;
  skos:description "Access policies are publicly available"@en ;
  schema:category "Interoperability|Legal Interoperability|FAIR Metadata Despite Restrictions to Data Access|Publishing of access policies even for restricted content" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000c4
  a skos:Concept ;
  skos:prefLabel "Human readable access documention"@en ;
  skos:description "Human readable access documentation is referred to by URI"@en ;
  schema:category "Interoperability|Legal Interoperability|FAIR Metadata Despite Restrictions to Data Access|Publishing of access policies even for restricted content" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000c5
  a skos:Concept ;
  skos:prefLabel "Machine-readable access policies"@en ;
  skos:description "Machine-readable access policies are supported"@en ;
  schema:category "Interoperability|Legal Interoperability|FAIR Metadata Despite Restrictions to Data Access|Publishing of access policies even for restricted content" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000c6
  a skos:Concept ;
  skos:prefLabel "Content Deposit Policy"@en ;
  skos:description "Policy or guidance exist for which content can be deposited into the repository"@en ;
  schema:category "Quality|Contextual Data Quality|Applicability and Alignment|Alignment" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

