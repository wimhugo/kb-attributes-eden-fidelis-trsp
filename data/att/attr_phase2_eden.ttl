  a skos:Concept ;
  skos:prefLabel "Guidance or matrix combining licenses"@en ;
  skos:description "Publishing compatibillity matrix or guidance on combining licenses"@en ;
  schema:category "Interoperability|Legal Interoperability|License Compatibility and Reusability|License alignment and combinability" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000aa
  a skos:Concept ;
  skos:prefLabel "User guidance"@en ;
  skos:description "Guidance for users how to choose combinable licenses"@en ;
  schema:category "Interoperability|Legal Interoperability|License Compatibility and Reusability|License alignment and combinability" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

