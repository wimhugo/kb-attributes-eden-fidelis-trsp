trsp:edenatt00002c
  a skos:Concept ;
  skos:prefLabel "Metadata levels"@en ;
  skos:description "List of indexed metadata levels per source (e.g. dataset level, file level, service level)?"@en ;
  schema:category "Interoperability|Technical Interoperability|Lack of Federated Discovery Across Domain|Metadata indexing at multiple levels" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000033
  a skos:Concept ;
  skos:prefLabel "URL to discovery API"@en ;
  skos:description "The URL to the discovery API"@en ;
  schema:category "Interoperability|Technical Interoperability|Lack of Federated Discovery Across Domain|Discovery APIs supporting varying granularity" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000036
  a skos:Concept ;
  skos:prefLabel "Level of granularity"@en ;
  skos:description "The levels of granularity which are supported in the discovery API"@en ;
