  a skos:Concept ;
  skos:prefLabel "License policy"@en ;
  skos:description "URI is published to the license policy in use"@en ;
  schema:category "Interoperability|Legal Interoperability|License Compatibility and Reusability|Use of standardized open licenses" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000ac
  a skos:Concept ;
  skos:prefLabel "Default license"@en ;
  skos:description "Indicates which license is set by default when none is provided by the depositor"@en ;
  schema:category "Interoperability|Legal Interoperability|License Compatibility and Reusability|Use of standardized open licenses" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000ad
  a skos:Concept ;
  skos:prefLabel "Standardized open licenses used"@en ;
  skos:description "List of supported license types is published"@en ;
  schema:category "Interoperability|Legal Interoperability|License Compatibility and Reusability|Use of standardized open licenses" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000ae
  a skos:Concept ;
  skos:prefLabel "Vocabulary and standards used"@en ;
  skos:description "Publishes the standard vocabularies or schemas used for licenses"@en ;
  schema:category "Interoperability|Legal Interoperability|Clarity and Automation of Legal Conditions|Machine-readable licensing terms" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000af
  a skos:Concept ;
  skos:prefLabel "URI resolution"@en ;
  skos:description "Metadata includes a URI to a machine-readable license expression"@en ;
  schema:category "Interoperability|Legal Interoperability|Clarity and Automation of Legal Conditions|Machine-readable licensing terms" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000b0
  a skos:Concept ;
  skos:prefLabel "Machine-readable license format"@en ;
  skos:description "Metadata includes machine-readable license format"@en ;
  schema:category "Interoperability|Legal Interoperability|Clarity and Automation of Legal Conditions|Machine-readable licensing terms" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt0000b3
  a skos:Concept ;
  skos:prefLabel "Machine-Readable Access and Usage Conditions"@en ;
  skos:description "Access rights and usage conditions for data should be clearly expressed in metadata to inform users and enable automated decision-making."@en ;
  schema:category "Interoperability|Legal Interoperability|Clarity and Automation of Legal Conditions|Metadata describing access and use conditions" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
