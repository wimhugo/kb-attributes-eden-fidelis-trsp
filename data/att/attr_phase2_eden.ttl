trsp:edenatt00000b
  a skos:Concept ;
  skos:prefLabel "Stored Information Types (Machine-Readable)"@en ;
  skos:description "Which types of information the repository stores in a machine-readable interface (software, analysis, raw data, etc....)"@en ;
  schema:category "Interoperability|Technical Interoperability|Format Fragmentation in Research Data|Support for both General-purpose and Domain-specific Formats" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00000c
  a skos:Concept ;
  skos:prefLabel "File Format Policy with Persistent Reference"@en ;
  skos:description "Policy exist that define the formatting of file formats, and/or the desired types by the repository"@en ;
  schema:category "Interoperability|Technical Interoperability|Format Fragmentation in Research Data|Support for both General-purpose and Domain-specific Formats" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00000d
  a skos:Concept ;
  skos:prefLabel "Supports metadata schema mapping"@en ;
  skos:description "Does the repository support the ability to map, transform and/or align metadata that comes in different schemas, standards, or structural formats?"@en ;
  schema:category "Interoperability|Technical Interoperability|Format Fragmentation in Research Data|Metadata Alignment across Heterogeneous Formats" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00000e
  a skos:Concept ;
  skos:prefLabel "Supports metadata schemas"@en ;
  skos:description "Does the repository support the ability to map, transform and/or align metadata that comes in different schemas, standards, or structural formats?"@en ;
  schema:category "Interoperability|Technical Interoperability|Format Fragmentation in Research Data|Metadata Alignment across Heterogeneous Formats" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00000f
  a skos:Concept ;
  skos:prefLabel "Supports metadata/ data format translation"@en ;
  skos:description "Does the repository use services or tools which are also available to translate, transform, mediate between different data formats (e.g. package structures, file formats, metadata standards)?"@en ;
  schema:category "Interoperability|Technical Interoperability|Format Fragmentation in Research Data|Integration Tools for Bridging Formats" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00001c
  a skos:Concept ;
  skos:prefLabel "Search level support - Advanced"@en ;
  skos:description "Does the repository support search on nested metadata?"@en ;
  schema:category "Interoperability|Technical Interoperability|Lack of Federated Discovery Across Domain|Top-level and fine-grained search mechanisms" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00001d
  a skos:Concept ;
  skos:prefLabel "Searchable Metadata Fields (Advanced Search Capabilities)"@en ;
  skos:description "List of the searchable metadata fields, both low (nested data) and high level search (e.g. Dublin Core)"@en ;
  schema:category "Interoperability|Technical Interoperability|Lack of Federated Discovery Across Domain|Top-level and fine-grained search mechanisms" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt00001f
  a skos:Concept ;
  skos:prefLabel "Search level support - Simple"@en ;
  skos:description "Does the repository support high-level search and discovery?"@en ;
  schema:category "Interoperability|Technical Interoperability|Lack of Federated Discovery Across Domain|Top-level and fine-grained search mechanisms" ;
  dcat:keyword "EDEN" ;
  owl:versionInfo "0.1" ;
  skos:inScheme trsp:ConceptScheme .

trsp:edenatt000024
  a skos:Concept ;
  skos:prefLabel "Federated query support"@en ;
  skos:description "Is the system capable of querying across domains to participate in external cross-domain discovery networks?"@en ;
  schema:category "Interoperability|Technical Interoperability|Lack of Federated Discovery Across Domain|Federated and cross-domain query support" ;
