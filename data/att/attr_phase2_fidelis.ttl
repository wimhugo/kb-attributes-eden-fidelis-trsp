  dct:contributor "EOSC FIDELIS WP5/6" ;
  dct:contributor "EOSC EDEN WP2" ;
  dct:description "A profile of repository and repository services attributes identified by EOSC FIDELIS TTRAM"@en 
  dct:modified "2026-05-07T00:00:00+00:00"^^xsd:datetime;
  dct:modified "2026-04-29T00:00:00+00:00"^^xsd:datetime ;
  dct:rights <https://spdx.org/licenses/CC0-1.0>;
  dct:title "EOSC EDEN Attribute Vocabulary Profile @en;
  skos:prefLabel "EDEN Attributes"@en .
  owl:versionInfo "0.4"@en;
  foaf:homepage  <https://github.com/wimhugo/kb-attributes-eden-fidelis-trsp/> .

