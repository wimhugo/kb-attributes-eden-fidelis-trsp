trsp:att139cd89a8a
  a skos:Concept ;
  skos:prefLabel "Community Engagement"@en ;
  skos:description "Demonstrable longer-term funding and income sources. Structural income is adequate. Revenue is justifiable, the source is clearly defined, and revenue does not come from selling the data or metadata holdings. Recovering justifiable cost, for example for disseminating or storing large data sets, is acceptable."@en ;
  schema:category "Sustainability|Financial Sustainability|Community Engagement" ;
  dcat:keyword "POSI" ;
  dcat:keyword "CTS" ;
  dcat:keyword "TRUST" ;
  owl:versionInfo "0.1" ;
