trsp:att1095e8cf4a
  a skos:Concept ;
  skos:prefLabel "Performance Assessment"@en ;
  skos:description "The extent to which formal assessments/ audits of performance have been obtained. These aspects relate to performance assessments that are associated with digital services in general, also soutside teh research output management landscape. It covers aspects of process quality (such as ISO 9000), information security (ISO 27001), and service management (FitSM)."@en ;
  schema:category "Performance|Performance Assessment" ;
  owl:versionInfo "0.1" ;
  skos:broader att.5ABD0E52C7 ;
  skos:inScheme trsp:ConceptScheme .

