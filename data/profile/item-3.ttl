trsp:profile.00BA218182 a trsp:Profile ;
    dct:title "ARCHE - A Resource Centre for the HumanitiEs" @en ;
    dct:description "Austrian national repository for digital humanities research data and cultural heritage resources. Provides long-term archiving and open access to linguistic corpora, historical data, cultural heritage datasets and humanities research outputs. Austrian node of CLARIN ERIC and DARIAH-EU." @en ;
    dct:identifier https://arche.acdh.oeaw.ac.at/browser/  ;
    dcat:endpointURL https://arche.acdh.oeaw.ac.at/browser/  ;
    trsp:hasProfileType "trsp:profile-type-repository"  .
