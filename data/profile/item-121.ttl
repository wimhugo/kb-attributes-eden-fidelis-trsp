@prefix trsp:   <https://example.org/trsp/> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix schema: <https://schema.org/> .
@prefix dcat:   <http://www.w3.org/ns/dcat#> .


trsp:profile.0.00E+00 a trsp:Profile ;
    dct:title "Radboud Data Repository" @en ;
    dct:description "Institutional research data repository of Radboud University providing long-term archiving and access for multidisciplinary research data. Supports FAIR principles and Dutch and European funder data sharing requirements. Particular strength in humanities, social sciences, and cognitive neuroscience." @en ;
    dct:identifier https://data.ru.nl/  ;
    dcat:endpointURL https://data.ru.nl/  ;
    trsp:hasProfileType "trsp:profile-type-repository"  .
