@prefix trsp:   <https://example.org/trsp/> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix schema: <https://schema.org/> .
@prefix dcat:   <http://www.w3.org/ns/dcat#> .


trsp:profile.002FA0AA0F a trsp:Profile ;
    dct:title "ASAP" @en ;
    dct:description "Automated Single-cell Analysis Portal (ASAP) – a collaborative web platform for analysing, visualising and publishing single-cell RNA-seq and multi-omics data. Allows researchers to import public datasets (GEO, ArrayExpress, SRA, BioProject) and private data, run analyses and share results. Incorporates scFAIR validation schema for single-cell data metadata." @en ;
    dct:identifier <https://asap.epfl.ch/>  ;
    dcat:endpointURL <https://asap.epfl.ch/>  ;
    trsp:hasProfileType "trsp:profile-type-repository"  .
