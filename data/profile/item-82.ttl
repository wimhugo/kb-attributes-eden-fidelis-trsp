trsp:profile.2E14441342 a trsp:Profile ;
    dct:title "Linguistic Data Consortium" @en ;
    dct:description "The Linguistic Data Consortium (LDC) is an open consortium that creates, collects, archives, and shares large collections of language data, including speech, text, and lexical resources, for research and technology development in linguistics and natural language processing." @en ;
    dct:identifier "10.25504/FAIRsharing.25a72c"  ;
    dcat:endpointURL <https://www.ldc.upenn.edu/>  ;
    trsp:hasProfileType "trsp:profile-type-repository"  .
