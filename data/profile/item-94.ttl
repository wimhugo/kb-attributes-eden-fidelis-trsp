trsp:profile.trsp:profile.165CB267FA a trsp:Profile ;
    dct:title "OrthoDB" @en ;
    dct:description "OrthoDB provides evolutionary and functional annotations of genes classified into groups of orthologs in a diverse sampling of eukaryotes, prokaryotes, and viruses." @en ;
