trsp:profile.trsp:profile.003C955045 a trsp:Profile ;
    dct:title "The Language Bank of Finland" @en ;
    dct:description "Finnish national infrastructure for language research providing access to text and speech corpora, lexical resources and language technology tools. Serves linguists and language technology researchers in Finland and internationally. Finnish node of CLARIN ERIC." @en ;
    dct:identifier https://www.kielipankki.fi/language-bank/  ;
    dcat:endpointURL https://www.kielipankki.fi/language-bank/  ;
    trsp:hasProfileType "trsp:profile-type-repository"  .
