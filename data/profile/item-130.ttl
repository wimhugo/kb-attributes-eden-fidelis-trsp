trsp:profile.trsp:profile.745403B02C a trsp:Profile ;
    dct:title "schema.org" @en ;
    dct:description "Schema.org is a joint effort, in the spirit of sitemaps.org, to improve the web by creating a structured data markup schema supported by major search engines." @en ;
