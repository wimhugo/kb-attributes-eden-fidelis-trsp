trsp:profile.trsp:profile.005B248EEE a trsp:Profile ;
    dct:title "DAIS - Digital Archive of the Serbian Academy of Sciences and Arts" @en ;
    dct:description "Institutional digital repository of the Serbian Academy of Sciences and Arts. Preserves and provides open access to the scientific and scholarly publications, books, journals, proceedings and research outputs produced by SANU members and affiliated institutes." @en ;
    dct:identifier https://dais.sanu.ac.rs/  ;
    dcat:endpointURL https://dais.sanu.ac.rs/  ;
    trsp:hasProfileType "trsp:profile-type-repository"  .
