trsp:profile.trsp:profile.005BC63AA9 a trsp:Profile ;
    dct:title "SWISSUbase" @en ;
    dct:description "Swiss national cross-disciplinary platform for the curation, preservation and dissemination of research data and metadata. Launched 2021 to succeed FORSbase. Covers social sciences (via FORS DSU), linguistics (via LaRS/CLARIN-CH) and other disciplines (via institutional DSUs). Metadata harvested by CESSDA, CLARIN and DARIAH." @en ;
    dct:identifier https://www.swissubase.ch/  ;
    dcat:endpointURL https://www.swissubase.ch/  ;
    trsp:hasProfileType "trsp:profile-type-repository"  .
