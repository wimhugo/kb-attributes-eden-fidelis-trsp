trsp:profile.235D1D5D91 a trsp:Profile ;
    dct:title "Open Data Repository of the National Academy of Sciences of Ukraine" @en ;
    dct:description "The open data repository DataverseUA of the National Academy of Sciences of Ukraine is a digital platform for storing, classifying and publishing the Academy's scientific data. The aim of the project is to establish an open data repository service for research conducted by scientific institutions affiliated with the National Academy of Sciences of Ukraine. The repository is intended to provide researchers, innovators, technology companies, and the general public with an accessible and reliable environment where they can publish, discover, and reuse data." @en ;
    dct:identifier "r3d100014746"  ;
    dcat:endpointURL https://opendata.nas.gov.ua/  ;
    trsp:hasProfileType "trsp:profile-type-repository"  .
