trsp:profile.0048D487E7 a trsp:Profile ;
    dct:title "Sikt Research Data Archive" @en ;
    dct:description "Norwegian national archive for social science and humanities research data. Acquires, curates and disseminates social science datasets for secondary analysis. Also responsible for data protection officer function for Norwegian research institutions and CESSDA Service Provider for Norway." @en ;
