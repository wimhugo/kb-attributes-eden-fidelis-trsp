trsp:profile.18B13EC70C a trsp:Profile ;
    dct:title "Copernicus Climate Change Service Portal" @en ;
    dct:description "The C3S portal offers access to the reference products generated by the Copernicus Climate Change Service that are derived from Sentinel reference products (Sentinel 1 and 3 primarily) along with other satellite observations and in-situ measurements. The C3S portal provides authoritative information concerning past, present, and future (forecasting) global climate." @en ;
    dct:identifier <https://cds.climate.copernicus.eu/>  ;
    dcat:endpointURL <https://cds.climate.copernicus.eu/>  ;
    trsp:hasProfileType "trsp:profile-type-repository"  .
