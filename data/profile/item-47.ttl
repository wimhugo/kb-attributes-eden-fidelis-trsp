@prefix trsp:   <https://example.org/trsp/> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix schema: <https://schema.org/> .
@prefix dcat:   <http://www.w3.org/ns/dcat#> .


trsp:profile.trsp:profile.001961A5E1 a trsp:Profile ;
    dct:title "DOME Registry" @en ;
    dct:description "Registry curating machine learning methods applied in biology from scientific publications. Implements the DOME (Data, Optimization, Model, Evaluation) recommendations for reporting supervised ML in biology. Assigns unique DOME identifiers and DOME scores to publications; supports community curation. Aims to improve reproducibility and transparency of ML in life sciences." @en ;
    dct:identifier https://registry.dome-ml.org/intro  ;
    dcat:endpointURL https://registry.dome-ml.org/intro  ;
    trsp:hasProfileType "trsp:profile-type-repository"  .
